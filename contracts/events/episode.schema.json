{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cognitive-twin.local/contracts/events/episode.schema.json",
  "title": "Episode",
  "type": "object",
  "required": [
    "episode_id",
    "event_ids",
    "episode_type",
    "summary",
    "salience",
    "entities",
    "goals",
    "memory_state",
    "created_at",
    "updated_at"
  ],
  "additionalProperties": false,
  "properties": {
    "episode_id": { "type": "string", "minLength": 1 },
    "event_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "episode_type": { "type": "string", "minLength": 1 },
    "summary": { "type": "string" },
    "salience": { "type": "number", "minimum": 0, "maximum": 1 },
    "entities": {
      "type": "array",
      "items": { "type": "string" }
    },
    "goals": {
      "type": "array",
      "items": { "type": "string" }
    },
    "outcome": { "type": ["string", "null"] },
    "memory_state": {
      "type": "string",
      "enum": ["raw", "curated", "consolidated", "archived", "invalidated"]
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "metadata": { "type": "object" }
  }
}
