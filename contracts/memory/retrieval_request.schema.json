{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cognitive-twin.local/contracts/memory/retrieval_request.schema.json",
  "title": "StructuredRetrievalRequest",
  "type": "object",
  "required": ["request_id"],
  "additionalProperties": false,
  "properties": {
    "request_id": { "type": "string", "minLength": 1 },
    "filters": { "$ref": "#/$defs/RetrievalFilter" },
    "actor_id": { "type": ["string", "null"] },
    "limit": { "type": "integer", "minimum": 1, "maximum": 100, "default": 50 },
    "offset": { "type": "integer", "minimum": 0, "default": 0 },
    "policy": { "$ref": "#/$defs/RetrievalPolicyScope" }
  },
  "$defs": {
    "RetrievalFilter": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "episode_type": { "type": ["string", "null"] },
        "memory_state": {
          "type": ["string", "null"],
          "enum": ["raw", "curated", "consolidated", "archived", "invalidated", null]
        },
        "min_salience": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "entity": { "type": ["string", "null"] },
        "goal": { "type": ["string", "null"] },
        "created_after": { "type": ["string", "null"], "format": "date-time" },
        "created_before": { "type": ["string", "null"], "format": "date-time" }
      }
    },
    "RetrievalPolicyScope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "actor_id": { "type": ["string", "null"] },
        "purpose": { "type": ["string", "null"] },
        "allowed_sensitivities": {
          "type": ["array", "null"],
          "items": {
            "type": "string",
            "enum": ["public", "internal", "private", "sensitive"]
          }
        },
        "allow_imported": { "type": "boolean", "default": false },
        "include_policy_decisions": { "type": "boolean", "default": true }
      }
    }
  }
}
