{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cognitive-twin.local/contracts/memory/retrieval_response.schema.json",
  "title": "RetrievalResponse",
  "type": "object",
  "required": ["request_id", "episode_ids", "events", "provenance_note"],
  "additionalProperties": false,
  "properties": {
    "request_id": { "type": "string", "minLength": 1 },
    "episode_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "events": {
      "type": "array",
      "items": { "$ref": "../events/event.schema.json" }
    },
    "provenance_note": { "type": "string" }
  }
}
