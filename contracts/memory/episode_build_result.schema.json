{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cognitive-twin.local/contracts/memory/episode_build_result.schema.json",
  "title": "EpisodeBuildResult",
  "type": "object",
  "required": ["request_id", "episode_id", "event_ids", "status"],
  "additionalProperties": false,
  "properties": {
    "request_id": { "type": "string", "minLength": 1 },
    "episode_id": { "type": "string", "minLength": 1 },
    "event_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "status": {
      "type": "string",
      "enum": ["succeeded", "failed"]
    },
    "error": { "type": ["string", "null"] }
  }
}
