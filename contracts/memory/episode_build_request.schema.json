{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cognitive-twin.local/contracts/memory/episode_build_request.schema.json",
  "title": "EpisodeBuildRequest",
  "type": "object",
  "required": [
    "request_id",
    "episode_id",
    "event_ids",
    "episode_type",
    "summary",
    "salience"
  ],
  "additionalProperties": false,
  "properties": {
    "request_id": { "type": "string", "minLength": 1 },
    "episode_id": { "type": "string", "minLength": 1 },
    "event_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "episode_type": { "type": "string", "minLength": 1 },
    "summary": { "type": "string" },
    "salience": { "type": "number", "minimum": 0, "maximum": 1 },
    "entities": {
      "type": "array",
      "items": { "type": "string" }
    },
    "goals": {
      "type": "array",
      "items": { "type": "string" }
    },
    "outcome": { "type": ["string", "null"] },
    "memory_state": {
      "type": "string",
      "enum": ["raw", "curated", "consolidated", "archived", "invalidated"]
    },
    "actor_id": { "type": ["string", "null"] }
  }
}
