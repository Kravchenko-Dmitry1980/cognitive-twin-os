# Cognitive Twin OS — environment template (Phase 0/1)
# Copy to .env for local development. No secrets required for Phase 1.

# Application
CTOS_ENV=development
CTOS_LOG_LEVEL=INFO

# Schema versions (defaults used if unset)
CTOS_EVENT_SCHEMA_VERSION=1.0.0
CTOS_EPISODE_SCHEMA_VERSION=1.0.0

# Future phases (not used in Phase 1)
# CTOS_DB_URL=
# CTOS_VECTOR_STORE_URL=
